# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — create tester accounts from Settings → Team (Project Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=

# OAuth — configure Google and Facebook in Supabase → Authentication → Providers
# Redirect URLs must include https://your-app.vercel.app/auth/callback and http://localhost:3000/auth/callback

# Production site URL (required for email sign-in redirects on Vercel)
# NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional — server-side only (AI Campaign Assistant). OpenAI API key.
OPENAI_API_KEY=

# Draft model routing (server-side only)
# Fast draft model — used for Draft for me, Draft again, Draft all (default: gpt-4o-mini)
# OPENAI_FAST_DRAFT_MODEL=gpt-4o-mini
# High-quality draft model — optional, not used by default (default: gpt-5-mini)
# OPENAI_QUALITY_DRAFT_MODEL=gpt-5-mini
# Legacy alias — maps to fast draft model if OPENAI_FAST_DRAFT_MODEL is unset
# OPENAI_MODEL=gpt-4o-mini

# AI Artwork — OpenAI Images model (server-side only, default: gpt-image-1)
# OPENAI_IMAGE_MODEL=gpt-image-1

# Artwork v2 — ChatGPT-style native image generation via Responses API (default: gpt-5.5)
# OPENAI_ARTWORK_ORCHESTRATOR_MODEL=gpt-5.5
# OPENAI_ARTWORK_IMAGE_QUALITY=high
# OPENAI_ARTWORK_REASONING_EFFORT=medium

# Meta auto-publish — Facebook Page + Instagram Business (server-side only)
# OAuth (recommended) — long-lived Page tokens via Facebook Login
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=https://your-domain.com/api/meta/oauth/callback
# Legacy env fallback (optional)
# META_FACEBOOK_PAGE_ID=
# META_INSTAGRAM_ACCOUNT_ID=
# META_PAGE_ACCESS_TOKEN=
# META_GRAPH_API_VERSION=v21.0
# Meta webhook verify token — set the same value in Meta App Dashboard → Webhooks
# META_WEBHOOK_VERIFY_TOKEN=

# Cron secret for /api/cron/* routes (meta-publish, calendar-subscribe-sync, story-post-reminders, inbox-sync)
# CRON_SECRET=

# Story post kit email reminders (Resend — server-side only)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=CampaignOS <notifications@yourdomain.com>
# Hours before scheduled post to send reminder (default 24 for daily cron; use 2 with hourly cron on Pro)
# STORY_REMINDER_HOURS_BEFORE=24

# Meta social captions — milestone feed/story copy (default: gpt-5-mini)
# OPENAI_META_CAPTION_MODEL=gpt-5-mini

# Canva Connect — direct design import (server-side secret + OAuth)
# CANVA_CLIENT_ID=
# CANVA_CLIENT_SECRET=
# CANVA_REDIRECT_URI=https://your-domain.com/api/canva/oauth/callback

# Optional — school Canva brand kit link (fallback when Canva Connect is not configured)
# NEXT_PUBLIC_CANVA_URL=https://www.canva.com/

# ---------------------------------------------------------------------------
# Sentry error monitoring (optional until you finish the Sentry dashboard steps)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://YOUR_PUBLIC_KEY@oXXXX.ingest.sentry.io/YYYY
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=hey-ralli
# SENTRY_PROJECT=heyralli
# SENTRY_ENVIRONMENT=development
# Temporary verification routes (/api/sentry-verify, /dev/sentry-verify)
# SENTRY_VERIFY_SECRET=
# Staging-only User Feedback widget (also auto-on for Vercel preview)
# NEXT_PUBLIC_SENTRY_USER_FEEDBACK=true
# Set to false to disable Sentry completely
# SENTRY_ENABLED=true

# ---------------------------------------------------------------------------
# Playwright Hey Ralli smoke tests (use a STAGING / TEST account only)
# ---------------------------------------------------------------------------
# HEY_RALLI_BASE_URL=http://localhost:3000
# HEY_RALLI_TEST_EMAIL=
# HEY_RALLI_TEST_PASSWORD=
# HEY_RALLI_TEST_EVENT_ID=

# Optional — CampaignOS marketing social profiles (header links on public pages)
# NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/your-page
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/your-handle

# Founding / beta access codes (server-side only, comma-separated or single code)
# CAMPAIGNOS_FOUNDING_ACCESS_CODES=CODE1,CODE2
# CAMPAIGNOS_BETA_ACCESS_CODE=
# Require a valid code for new school signup (default: true; set false for local dev only)
# CAMPAIGNOS_REQUIRE_ACCESS_CODE=true

# Optional — server-side only (Today page weather). OpenWeatherMap API key.
# WEATHER_API_KEY=your-openweathermap-key

# Monday.com OAuth — playbook task sync (server-side only)
# MONDAY_CLIENT_ID=
# MONDAY_CLIENT_SECRET=
# Optional — must match Monday Developer Center → OAuth redirect URLs exactly
# Local dev (also register this URL in Developer Center):
# MONDAY_REDIRECT_URI=http://localhost:3000/api/monday/oauth/callback
# For local Monday OAuth, leave NEXT_PUBLIC_SITE_URL unset (defaults to http://localhost:3000).
# If NEXT_PUBLIC_SITE_URL points at Vercel, OAuth redirect_uri will use production, not localhost.
